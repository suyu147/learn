# =============================================================================
# SmartLearn — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -- Docker Compose Ports (optional) -----------------------------------------
APP_PORT=3000
DB_PORT=5432

# -- Database -----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartlearn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartlearn

# -- AI Provider (primary) ----------------------------------------------------
# Supported: spark | openai | anthropic | google | deepseek | kimi | glm
#            qwen | minimax | siliconflow | doubao | grok
AI_PROVIDER=spark
AI_MODEL=spark-4.0-turbo
AI_API_KEY=
AI_BASE_URL=https://spark-api-open.xf-yun.com/v1

# -- AI Provider API Keys -----------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=
MINIMAX_API_KEY=
SILICONFLOW_API_KEY=
DOUBAO_API_KEY=
GROK_API_KEY=
SPARK_API_KEY=

# -- Spark (iFlytek) ----------------------------------------------------------
SPARK_API_SECRET=
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# -- Image Generation ---------------------------------------------------------
# Provider: openai | siliconflow | doubao
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=
IMAGE_GEN_MODEL=

# -- Doubao (ByteDance) Image Generation (optional) ---------------------------
DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com
DOUBAO_IMAGE_MODEL=doubao-seedream-4-5-251128

# -- Video Generation (RunwayML) -----------------------------------------------
# Provider: runwayml | pika (pika not yet implemented)
DT_VIDEO_PROVIDER=runwayml
RUNWAYML_API_SECRET=
RUNWAYML_MODEL=gen4_turbo
RUNWAYML_BASE_URL=https://api.runwayml.com/v1

# -- Voice / TTS --------------------------------------------------------------
# Provider: openai | edge (elevenlabs not yet implemented)
DT_VOICE_PROVIDER=openai

# -- Sandbox (Piston API) -----------------------------------------------------
# URL of a Piston API instance for code execution
# Example: https://emkc.org/api/v2/piston or self-hosted
DT_SANDBOX_URL=

# -- Web Search ---------------------------------------------------------------
# Provider: tavily | brave | duckduckgo (auto-fallback if key missing)
DT_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=

# -- Auth Mode ----------------------------------------------------------------
# disabled = no authentication (single-user, auto-login)
# single   = single user mode (one account, auto-created)
# multi    = multi-user mode (registration + login required)
AUTH_MODE=disabled
JWT_SECRET=change-me-in-production
SINGLE_USER_NAME=admin

# -- MCP Servers (Model Context Protocol) ------------------------------------
# JSON array of MCP server configurations. Each server auto-registers tools
# with the DeepTutor agent. Supports stdio / sse / streamable-http transports.
#
# Recommended MCP servers (install first: npm install -g <package>):
#   @modelcontextprotocol/server-filesystem    — 文件读写 / 目录浏览
#   @modelcontextprotocol/server-postgres      — PostgreSQL 查询
#   @modelcontextprotocol/server-sequential-thinking — 结构化分步推理
#   @modelcontextprotocol/server-memory         — 知识图谱持久化记忆
#   @modelcontextprotocol/server-brave-search   — Brave 搜索（需要 BRAVE_API_KEY）
#
# Example:
#   DT_MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/path/to/workspace"],"enabledTools":["*"]}]
DT_MCP_SERVERS=

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=info
LLM_THINKING_DISABLED=true
