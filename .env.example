# =============================================================================
# SmartLearn — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -- Docker Compose Ports (optional) -----------------------------------------
APP_PORT=3000
DB_PORT=5432

# -- Database -----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartlearn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartlearn

# -- AI Provider (primary) ----------------------------------------------------
# Supported: spark | openai | anthropic | google | deepseek | kimi | glm
#            qwen | minimax | siliconflow | doubao | grok
AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1

# -- AI Provider API Keys -----------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=
MINIMAX_API_KEY=
SILICONFLOW_API_KEY=
DOUBAO_API_KEY=
GROK_API_KEY=
SPARK_API_KEY=

# -- Spark (iFlytek) ----------------------------------------------------------
SPARK_API_SECRET=
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# -- Vision Proxy (fallback when main model lacks vision) ---------------------
# Used to describe images when the main chat model doesn't support vision.
# Provider: any vision-capable provider (glm, openai, google, doubao, etc.)
# GLM users: VISION_PROVIDER=glm, VISION_MODEL=glm-4.6v-flash
#  using GLM_API_KEY — no extra API key needed!
VISION_PROVIDER=glm
VISION_MODEL=glm-4.6v-flash
VISION_API_KEY=
VISION_BASE_URL=

# -- Image Generation ---------------------------------------------------------
# Provider: openai | siliconflow | doubao
IMAGE_GEN_PROVIDER=doubao
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=https://api.siliconflow.cn/v1
IMAGE_GEN_MODEL=stabilityai/stable-diffusion-3-5-large

# -- Doubao (ByteDance) Image Generation (optional) ---------------------------
DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com
DOUBAO_IMAGE_MODEL=doubao-seedream-4-5-251128

# -- Video Generation (RunwayML) -----------------------------------------------
# Provider: runwayml | pika (pika not yet implemented)
DT_VIDEO_PROVIDER=runwayml
RUNWAYML_API_SECRET=
RUNWAYML_MODEL=gen4_turbo
RUNWAYML_BASE_URL=https://api.runwayml.com/v1

# -- Voice / TTS --------------------------------------------------------------
# Provider: openai | edge (elevenlabs not yet implemented)
DT_VOICE_PROVIDER=openai

# -- Sandbox (Piston API) -----------------------------------------------------
# URL of a Piston API instance for code execution
# Docker Compose auto-provisions a sandbox container; default: http://sandbox:2000
# For local dev without Docker: https://emkc.org/api/v2/piston or self-hosted
PISTON_API_URL=http://sandbox:2000
PISTON_API_KEY=

# -- Web Search ---------------------------------------------------------------
# Provider: tavily | brave | duckduckgo (auto-fallback if key missing)
DT_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=

# -- Auth Mode ----------------------------------------------------------------
# disabled = no authentication (single-user, auto-login)
# single   = single user mode (one account, auto-created)
# multi    = multi-user mode (registration + login required)
AUTH_MODE=multi
# REQUIRED: Generate with `openssl rand -hex 32` or similar. Docker Compose will refuse to start without it.
JWT_SECRET=
SINGLE_USER_NAME=admin

# -- Encryption (AES-256 for API keys stored in DB) ----------------------------
# REQUIRED: Generate with `openssl rand -hex 32`. Used to encrypt user API keys at rest.
DT_ENCRYPTION_SECRET=

# -- MCP Servers (Model Context Protocol) ------------------------------------
# JSON array of MCP server configs. Each server exposes tools to the AI agent.
# Recommended MCP servers (install first: npm install -g <package>):
#   @modelcontextprotocol/server-filesystem    — 文件读写 / 目录浏览
#   @modelcontextprotocol/server-postgres      — PostgreSQL 查询
#   @modelcontextprotocol/server-sequential-thinking — 结构化分步推理
#   @modelcontextprotocol/server-memory         — 知识图谱持久化记忆
#   @modelcontextprotocol/server-brave-search   — Brave 搜索（需要 BRAVE_API_KEY）
#
# Example:
#   DT_MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/path/to/workspace"],"enabledTools":["*"]}]
DT_MCP_SERVERS=

# -- Embedding (RAG vector retrieval) -----------------------------------------
DT_EMBEDDING_PROVIDER=siliconflow
DT_EMBEDDING_API_KEY=
DT_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
DT_EMBEDDING_MODEL=BAAI/bge-m3
# DT_EMBEDDING_DIMENSIONS — bge-m3 outputs 1024d by default, no need to specify

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=info
LLM_THINKING_DISABLED=true
