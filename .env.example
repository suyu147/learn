# =============================================================================
# SmartLearn — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -- Docker Compose Ports (optional) -----------------------------------------
APP_PORT=3000
DB_PORT=5432

# -- Database -----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartlearn

# -- AI Provider (primary) ----------------------------------------------------
# Supported: spark | openai | anthropic | google | deepseek | kimi | glm
#            qwen | minimax | siliconflow | doubao | grok
AI_PROVIDER=spark
AI_MODEL=spark-4.0-turbo
AI_API_KEY=
AI_BASE_URL=https://spark-api-open.xf-yun.com/v1

# -- AI Provider API Keys -----------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
QWEN_API_KEY=
MINIMAX_API_KEY=
SILICONFLOW_API_KEY=
DOUBAO_API_KEY=
GROK_API_KEY=
SPARK_API_KEY=

# -- Spark (iFlytek) ----------------------------------------------------------
SPARK_API_SECRET=
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1

# -- Image Generation ---------------------------------------------------------
# Provider: openai | siliconflow | doubao
DT_IMAGE_PROVIDER=openai
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=
IMAGE_GEN_MODEL=

# -- Video Generation (placeholder) -------------------------------------------
DT_VIDEO_PROVIDER=placeholder

# -- Voice / TTS --------------------------------------------------------------
# Provider: openai | edge
DT_VOICE_PROVIDER=openai

# -- Sandbox (Piston API) -----------------------------------------------------
# URL of a Piston API instance for code execution
# Example: https://emkc.org/api/v2/piston or self-hosted
DT_SANDBOX_URL=

# -- Web Search ---------------------------------------------------------------
TAVILY_API_KEY=

# -- Auth Mode ----------------------------------------------------------------
# disabled = no authentication (single-user, auto-login)
# single   = single user mode (one account, auto-created)
# multi    = multi-user mode (registration + login required)
AUTH_MODE=disabled
JWT_SECRET=change-me-in-production
SINGLE_USER_NAME=admin

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=info
LLM_THINKING_DISABLED=true
